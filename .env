# Energy Enterprise Platform - Environment Template
# Copy this to .env and configure for your environment

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=energy
MYSQL_PASSWORD=energy
MYSQL_HOST=mysql
MYSQL_PORT=3306

# Database Names
DB_DEVICE=energy_device_db
DB_RULE=energy_rule_db
DB_ANALYTICS=energy_analytics_db
DB_EXPORT=energy_export_db
DB_REPORTING=energy_reporting_db

# ===========================================
# INFLUXDB CONFIGURATION
# ===========================================
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=energy-token
INFLUXDB_ORG=energy-org
INFLUXDB_BUCKET=telemetry

# ===========================================
# MINIO/S3 CONFIGURATION
# ===========================================
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_ENDPOINT=minio:9000
MINIO_EXTERNAL_URL=http://localhost:9000
#MINIO_EXTERNAL_URL=http://100.52.248.60:9000
S3_BUCKET=energy-platform-datasets

# ===========================================
# MQTT/EMQX CONFIGURATION
# ===========================================
MQTT_BROKER_HOST=emqx
MQTT_BROKER_PORT=1883
MQTT_WS_PORT=8083

# ===========================================
# SERVICE CONFIGURATION
# ===========================================
ENVIRONMENT=production
LOG_LEVEL=INFO

# Device Service
DEVICE_SERVICE_PORT=8000

# Data Service
DATA_SERVICE_PORT=8081
DATA_SERVICE_HOST=0.0.0.0

# Rule Engine Service
RULE_ENGINE_PORT=8002

# Analytics Service
ANALYTICS_PORT=8003

# Data Export Service
DATA_EXPORT_PORT=8080
DATA_EXPORT_HOST=0.0.0.0

# Reporting Service
REPORTING_PORT=8085
REPORTING_HOST=0.0.0.0

# UI Web
UI_PORT=3000

# ===========================================
# EXTERNAL URLs (For Production)
# ===========================================
EXTERNAL_URL=http://localhost:3000
API_EXTERNAL_URL=http://localhost:8000

# ===========================================
# AWS CONFIGURATION (Optional)
# ===========================================
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://minio:9000

# ===========================================
# EMAIL ALERT CONFIGURATION
# ===========================================
EMAIL_ENABLED=true
SMTP_SERVER=smtp.gmail.com
EMAIL_SENDER=Support@cittagent.com
EMAIL_PASSWORD=gcoerqbykfrgfvsf
